# Copie para .env e preencha. O .env NUNCA deve ser versionado.

# --- LLM (padrao: Claude via Anthropic API) ---
# Identificador do modelo no formato LiteLLM. Confirme o nome atual do modelo
# na documentacao da Anthropic antes de fixar.
ADK_MODEL=anthropic/claude-sonnet-4-5
ANTHROPIC_API_KEY=

# --- Alternativa local/offline (Ollama / Llama 3) ---
# Para rodar sem chave paga, suba o Ollama e use, por exemplo:
# ADK_MODEL=ollama_chat/llama3
# OLLAMA_API_BASE=http://localhost:11434

# --- Sentimento (FinBERT-PT-BR) ---
SENTIMENT_MODEL=lucas-leme/FinBERT-PT-BR
# Diretorio de cache do HuggingFace (opcional)
HF_HOME=.hf_cache
